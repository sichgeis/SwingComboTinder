# Image API provider used by the local Studio and batch CLI: openai or litellm.
IMAGE_API_PROVIDER=openai

# Direct OpenAI configuration. Keep the real key in .env; never commit it.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional direct API override. The default is https://api.openai.com.
# Both root and /v1 forms work.
# OPENAI_BASE_URL=https://api.openai.com

# To use LiteLLM instead, set IMAGE_API_PROVIDER=litellm and uncomment these:
# LITELLM_API_KEY=sk-your-litellm-key
# LITELLM_BASE_URL=https://litellm.example.com

# Direct OpenAI model name or image-capable alias configured in LiteLLM.
IMAGE_MODEL=gpt-image-2

# Image output settings. 1024x1536 is an exact 2:3 card ratio.
IMAGE_SIZE=1024x1536
IMAGE_QUALITY=medium

# Local tool settings
REQUEST_TIMEOUT_SECONDS=300
IMAGE_STUDIO_PORT=4174

# Logging: error, warn, info, or debug. Debug includes request attempts and error stacks.
IMAGE_STUDIO_LOG_LEVEL=info
