# OpenAI API key used by the local image studio and batch CLI.
# Keep the real value in .env; never commit it.
OPENAI_API_KEY=sk-your-openai-api-key

# GPT Image model selected for reference-driven card generation.
IMAGE_MODEL=gpt-image-2

# Image output settings. 1024x1536 is an exact 2:3 card ratio.
IMAGE_SIZE=1024x1536
IMAGE_QUALITY=medium

# Local tool settings
REQUEST_TIMEOUT_SECONDS=300
IMAGE_STUDIO_PORT=4174
