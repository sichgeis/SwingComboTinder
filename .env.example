# LiteLLM virtual key or API key used by the local image studio and batch CLI.
# Keep the real value in .env; never commit it.
LITELLM_API_KEY=sk-your-litellm-key

# Base URL of the LiteLLM proxy. Both forms work:
#   https://litellm.example.com
#   https://litellm.example.com/v1
LITELLM_BASE_URL=https://litellm.example.com

# Image-capable model alias configured in the LiteLLM proxy.
IMAGE_MODEL=gpt-image-2

# Image output settings. 1024x1536 is an exact 2:3 card ratio.
IMAGE_SIZE=1024x1536
IMAGE_QUALITY=medium

# Local tool settings
REQUEST_TIMEOUT_SECONDS=300
IMAGE_STUDIO_PORT=4174
